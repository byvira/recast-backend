# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=SaaS Backend
DEBUG=false

# ENVIRONMENT: "development" | "production"
# development → OTP printed to console, CORS allows localhost
# production  → OTP sent via Resend/Twilio, CORS restricted to PRODUCTION_DOMAIN
ENVIRONMENT=development

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-random-hex-string

# ── OTP / Auth limits ────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_MAX_SENDS_PER_HOUR=5
OTP_MAX_SENDS_PER_DAY=10
OTP_COOLDOWN_SECONDS=60
OTP_LOCK_MINUTES=15
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ISSUER=saas-backend
JWT_AUDIENCE=saas-api

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# ── SMS — Twilio ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# ── LLM provider ─────────────────────────────────────────────────────────────
# LLM_PROVIDER options: groq | gemini  (default: groq)
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-key-here
GEMINI_API_KEY=your-gemini-key-here

STRIPE_SECRET_KEY=sk_test_...

# ── Data stores ───────────────────────────────────────────────────────────────
# Database name must be included in the URL for get_default_database() to work
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?appName=Recast
REDIS_URL=redis://default:<password>@<host>:<port>

# ── Storage — Cloudinary ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Only used in development (ENVIRONMENT=development).
# In production, set PRODUCTION_DOMAIN instead.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Production domain — REQUIRED when ENVIRONMENT=production
# Example: https://app.yourdomain.com
PRODUCTION_DOMAIN=

# ── Free tier ─────────────────────────────────────────────────────────────────
FREE_CREDITS_LIMIT=100
